{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/renewal-reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/whatsapp-health-check",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/message-retry",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/usage-reset",
      "schedule": "5 0 1 * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "30 2 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/app/(.*)",
      "dest": "/public/app/$1"
    },
    {
      "src": "/references/(.*)",
      "dest": "/public/references/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/features",
      "dest": "/index.html"
    },
    {
      "src": "/pricing",
      "dest": "/index.html"
    },
    {
      "src": "/support",
      "dest": "/index.html"
    },
    {
      "src": "/login",
      "dest": "/index.html"
    },
    {
      "src": "/register",
      "dest": "/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/index.html"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "/index.html"
    }
  ]
}
