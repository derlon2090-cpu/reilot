# App
NEXT_PUBLIC_APP_NAME=Renvix
NEXT_PUBLIC_APP_URL=
NODE_ENV=production

# Database - Neon
DATABASE_URL=
DIRECT_URL=

# Auth - Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# WhatsApp - Evolution API self-hosted
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=

# Email - Resend
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=Renvix <noreply@notify.renvix.app>
SUPPORT_EMAIL=support@renvix.app

# Payments - Moyasar
PAYMENT_PROVIDER=moyasar
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=

# Security
JWT_SECRET=
CRON_SECRET=
ENCRYPTION_KEY=
ORDER_LINK_ENCRYPTION_KEY=
MFA_ENCRYPTION_KEY=

# File storage - Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Private admin console (server-only)
ADMIN_SETUP_TOKEN=
# The login URL is /advanced-pro-control. ADMIN_EMAIL is used only by:
# ADMIN_EMAIL=user@renvix.app npm run admin:promote
ADMIN_EMAIL=

# Salla merchant integration (server-only)
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_REDIRECT_URI=
SALLA_API_BASE_URL=https://api.salla.dev/admin/v2
SALLA_OAUTH_STATE_SECRET=
SALLA_WEBHOOK_SECRET=

# WhatsApp Safety Defaults
DEFAULT_SAFE_MODE_ENABLED=true
DEFAULT_DAILY_MESSAGE_LIMIT=100
DEFAULT_HOURLY_MESSAGE_LIMIT=20
DEFAULT_MIN_DELAY_SECONDS=20
DEFAULT_MAX_DELAY_SECONDS=90
DEFAULT_QUIET_HOURS_START=21:00
DEFAULT_QUIET_HOURS_END=09:00
DEFAULT_MAX_BLOCK_RISK_SCORE=70
# Optional permanent administrator bootstrap (keep the password outside Git).
ADMIN_BOOTSTRAP_EMAIL=admin@renvix.app
ADMIN_BOOTSTRAP_USERNAME=renvix_root_7X9K
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Renvix Admin
