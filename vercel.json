{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run db:migrate && npm run build",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://reilot.vercel.app",
    "BETTER_AUTH_URL": "https://reilot.vercel.app",
    "COOKIE_SECURE": "true",
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://51.210.77.137/api/:path*"
    },
    {
      "source": "/dashboard",
      "destination": "http://51.210.77.137/dashboard"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "http://51.210.77.137/dashboard/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/renewal-reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/whatsapp-health-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/message-retry",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/usage-reset",
      "schedule": "5 0 1 * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "30 2 * * *"
    }
  ]
}
