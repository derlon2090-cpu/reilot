{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/renewal-reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/whatsapp-health-check",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/message-retry",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/usage-reset",
      "schedule": "5 0 1 * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "30 2 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/features",
      "destination": "/index.html"
    },
    {
      "source": "/pricing",
      "destination": "/index.html"
    },
    {
      "source": "/support",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/register",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/index.html"
    }
  ]
}
