NODE_ENV=production
NEXT_PUBLIC_APP_NAME=RenewPilot AI
NEXT_PUBLIC_APP_URL=http://51.210.77.137

POSTGRES_USER=renewpilot
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=renewpilot
DATABASE_URL=postgresql://renewpilot:replace-with-a-long-random-password@database:5432/renewpilot
DATABASE_SSL=false

BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://51.210.77.137
JWT_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-32-byte-secret

# Salla merchant integration (server-only)
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_REDIRECT_URI=http://51.210.77.137/api/integrations/salla/callback
SALLA_OAUTH_STATE_SECRET=replace-with-a-long-random-secret
SALLA_WEBHOOK_SECRET=

WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=
EVOLUTION_WEBHOOK_URL=http://app:3000/api/webhooks/evolution
EVOLUTION_PAIRING_CODE_SUPPORTED=true

EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=RenewPilot AI <noreply@your-verified-domain.com>
SUPPORT_EMAIL=support@your-verified-domain.com

PAYMENT_PROVIDER=moyasar
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=

DEFAULT_SAFE_MODE_ENABLED=true
DEFAULT_DAILY_MESSAGE_LIMIT=100
DEFAULT_HOURLY_MESSAGE_LIMIT=20
DEFAULT_MIN_DELAY_SECONDS=20
DEFAULT_MAX_DELAY_SECONDS=90
DEFAULT_QUIET_HOURS_START=21:00
DEFAULT_QUIET_HOURS_END=09:00
DEFAULT_MAX_BLOCK_RISK_SCORE=70
