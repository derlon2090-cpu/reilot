# App
NEXT_PUBLIC_APP_NAME=RenewPilot AI
NEXT_PUBLIC_APP_URL=
NODE_ENV=production

# Database - Neon
DATABASE_URL=
DIRECT_URL=

# Auth - Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# WhatsApp - Whapi Partner
WHATSAPP_PROVIDER=whapi
WHAPI_PARTNER_API_KEY=
WHAPI_PARTNER_BASE_URL=
WHAPI_BASE_URL=https://gate.whapi.cloud
WHAPI_WEBHOOK_SECRET=

# Email - Resend
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SUPPORT_EMAIL=

# Payments - Moyasar
PAYMENT_PROVIDER=moyasar
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=

# Security
JWT_SECRET=
CRON_SECRET=
ENCRYPTION_KEY=

# WhatsApp Safety Defaults
DEFAULT_SAFE_MODE_ENABLED=true
DEFAULT_DAILY_MESSAGE_LIMIT=100
DEFAULT_HOURLY_MESSAGE_LIMIT=20
DEFAULT_MIN_DELAY_SECONDS=20
DEFAULT_MAX_DELAY_SECONDS=90
DEFAULT_QUIET_HOURS_START=21:00
DEFAULT_QUIET_HOURS_END=09:00
DEFAULT_MAX_BLOCK_RISK_SCORE=70
